APP_NAME="Shopify App"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://icons-app-shopify-laravel.test
SHOPIFY_WEBHOOK_URL="https://icons-app-shopify-laravel.test"
ADMIN_EMAIL="sandbox@sandbox.com"

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=iconito_db
DB_USERNAME=root
DB_PASSWORD=

DB_CONNECTION2=mysql2
DB_HOST2=127.0.0.1
DB_PORT2=3306
DB_DATABASE2=iconito_db
DB_USERNAME2=root
DB_PASSWORD2=


BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SEGMENT_QUEUE=database
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379



AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-west-2
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_ICON_HOST=
VITE_AWS_ICON_HOST="${AWS_ICON_HOST}"
CLOUDFRONT_ICON_HOST=
VITE_CLOUDFRONT_ICON_HOST="${CLOUDFRONT_ICON_HOST}"
MIX_CLOUDFRONT_ICON_HOST="${CLOUDFRONT_ICON_HOST}"
VITE_CRISP_WEBSITE_ID=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
7
SHOPIFY_MANUAL_MIGRATIONS=1
SHOPIFY_APP_NAME="${APP_NAME}"
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_SCOPES='read_products,write_products,read_themes,write_themes'
VITE_APP_URL=${APP_URL}
MIX_APP_URL=${APP_URL}
SHOPIFY_BILLING_ENABLED=0
AFTER_AUTHENTICATE_JOB_INLINE=true
AFTER_AUTHENTICATE_JOB_INLINE=true
SHOPIFY_HAS_TEST_PLAN=true
SHOPIFY_APP_STORE_ICONITO_HANDLE="guarantee-icons-trust-badges"
VITE_SHOPIFY_APP_STORE_ICONITO_HANDLE="${SHOPIFY_APP_STORE_ICONITO_HANDLE}"


SHOPIFY_ICONITO_APP_EXTENSION_NAME="app-embed"
SEGMENT_KEY=
SHOPIFY_ICONITO_APP_EXTENSION_ID=
VITE_SHOPIFY_ICONITO_APP_EXTENSION_NAME="app-embed"
VITE_SHOPIFY_ICONITO_APP_EXTENSION_ID=

SENTRY_LARAVEL_DSN=""
SENTRY_TRACES_SAMPLE_RATE=0.5